# ╔══════════════════════════════════════════════╗
# ║     Nekron Bot — Environment Variables       ║
# ║     Paste into Railway Raw Editor            ║
# ╚══════════════════════════════════════════════╝

# ── REQUIRED ─────────────────────────────────────────────────

# Bot Token — discord.com/developers → Your App → Bot → Reset Token
DISCORD_TOKEN=

# Application ID — discord.com/developers → Your App → General Information
CLIENT_ID=

# Your Discord Server ID — Right click server name → Copy Server ID
GUILD_ID=

# Anthropic API Key — console.anthropic.com → API Keys → Create Key
ANTHROPIC_KEY=

# ── CHANNEL IDs ───────────────────────────────────────────────
# Enable Developer Mode first:
# Discord Settings → Advanced → Developer Mode ON
# Then right click any channel → Copy Channel ID

# Channel where daily leaderboard posts every night
DAILY_LB_CHANNEL=

# Channel where Good Morning posts every day at 7AM
DAILY_MSG_CHANNEL=

# Default announcement channel
ANNOUNCE_CHANNEL=

# Category ID for ticket channels (right click category → Copy ID)
TICKET_CATEGORY_ID=

# Channel where ticket open/close logs go
TICKET_LOG_CHANNEL=

# Channel where level up messages go
LEVELUP_CHANNEL=
